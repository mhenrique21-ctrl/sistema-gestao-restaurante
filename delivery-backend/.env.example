# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/delivery_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delivery_db
DB_USER=postgres
DB_PASSWORD=sua_senha

# JWT
JWT_SECRET=seu_jwt_secret_super_seguro_aqui
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_sua_chave_aqui
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_aqui

# Asaas (PIX online)
ASAAS_API_KEY=sua_api_key_do_asaas_aqui
ASAAS_ENV=sandbox
# Token de acesso configurado no painel Asaas > Integrações > Webhooks.
# Deve ser IDÊNTICO ao valor colado aqui — cuidado com espaço/quebra de linha
# extra ao colar em produção (Railway), pois isso quebra a confirmação do PIX.
ASAAS_WEBHOOK_TOKEN=seu_token_de_webhook_do_asaas_aqui

# App
PORT=4000
NODE_ENV=development
